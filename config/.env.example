MARKET_SEGMENT=global-south        # or global-north
ANTHROPIC_API_KEY=sk-ant-...
APIFY_TOKEN=                        # optional
AI_BACKEND=ollama                   # ollama | deepseek | fallback
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=mistral
DEEPSEEK_API_KEY=
AI_CACHE_TTL=300

# Global North market segment
# MARKET_SEGMENT=global-north   # uncomment to enable GN features

# CORE API key (optional, for CORE search source — free at https://core.ac.uk/services/api)
# CORE_API_KEY=

# Deployment mode
APP_MODE=single_user              # single_user (default) | multi_user

# JWT secret — CHANGE THIS in production
SECRET_KEY=dev-secret-change-in-production
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=7
